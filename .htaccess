# ============================================================
# EZ FINANCE — .htaccess
# ============================================================

# ===== ЧПУ — убираем .html из URL =====
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# ===== Редирект с .html на ЧПУ =====
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]

# ===== 404 страница =====
ErrorDocument 404 /404.html

# ===== КЭШИРОВАНИЕ СТАТИКИ =====
<FilesMatch "\.(css|js|svg|png|jpg|jpeg|webp|woff2)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
</FilesMatch>

# ===== БЕЗОПАСНОСТЬ =====
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "DENY"
Header set Referrer-Policy "strict-origin-when-cross-origin"

# ===== HSTS =====
Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

# ===== СЖАТИЕ GZIP =====
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml text/xml
</IfModule>

# ===== ЗАПРЕТ ДОСТУПА К СКРЫТЫМ ФАЙЛАМ =====
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
